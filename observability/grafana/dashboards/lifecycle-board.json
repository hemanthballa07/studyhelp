{
  "id": null,
  "uid": "studyhelp-lifecycle",
  "title": "Lifecycle Board",
  "schemaVersion": 36,
  "version": 1,
  "refresh": "30s",
  "time": {"from": "now-1h", "to": "now"},
  "timezone": "browser",
  "tags": ["studyhelp", "lifecycle"],
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Question Intake Rate",
      "gridPos": {"x": 0, "y": 0, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "sum(rate(lifecycle_question_posted_total[5m]))",
          "legendFormat": "questions/s"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "reqps"}}
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Dedup Hit / Miss Rate",
      "gridPos": {"x": 12, "y": 0, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "sum(rate(lifecycle_dedup_result_total[5m])) by (result)",
          "legendFormat": "{{result}}"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "reqps"}}
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Claim Success Rate (5m)",
      "gridPos": {"x": 0, "y": 8, "w": 6, "h": 4},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "sum(rate(expertportal_claim_count_total{outcome=\"WON\"}[5m])) / sum(rate(expertportal_claim_count_total[5m])) * 100",
          "legendFormat": "Claim %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": 0}, {"color": "yellow", "value": 30}, {"color": "green", "value": 60}]}
        }
      }
    },
    {
      "id": 4,
      "type": "gauge",
      "title": "Claimable Queue Depth",
      "gridPos": {"x": 6, "y": 8, "w": 6, "h": 4},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "claimable_queue_depth",
          "legendFormat": "Depth"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": 0}, {"color": "yellow", "value": 50}, {"color": "red", "value": 100}]}
        }
      }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "QC Pass Rate (1h)",
      "gridPos": {"x": 12, "y": 8, "w": 6, "h": 4},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "sum(rate(qc_review_count_total{outcome=\"PASS\"}[1h])) / sum(rate(qc_review_count_total[1h])) * 100",
          "legendFormat": "QC Pass %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": 0}, {"color": "yellow", "value": 50}, {"color": "green", "value": 70}]}
        }
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Claim Outcome Rate",
      "gridPos": {"x": 0, "y": 12, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "sum(rate(expertportal_claim_count_total[5m])) by (outcome)",
          "legendFormat": "{{outcome}}"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "reqps"}}
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "QC Outcome Breakdown",
      "gridPos": {"x": 12, "y": 12, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "sum(rate(qc_review_count_total[5m])) by (outcome)",
          "legendFormat": "{{outcome}}"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "reqps"}}
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "AI Pipeline Decision Breakdown",
      "gridPos": {"x": 0, "y": 20, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "sum(rate(ai_decision_count_total[5m])) by (outcome)",
          "legendFormat": "{{outcome}}"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "reqps"}}
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "HTTP Error Rate by Endpoint",
      "gridPos": {"x": 12, "y": 20, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{status=~\"5..\"}[5m])) by (uri)",
          "legendFormat": "{{uri}}"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "reqps"}}
    }
  ]
}
